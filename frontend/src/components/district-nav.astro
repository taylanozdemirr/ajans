---
import { DISTRICTS } from '@/data/districts';

interface Props {
	/** Optional: hide this slug (e.g. the current district page). */
	exclude?: string;
	/** Section heading. */
	title?: string;
}

const { exclude, title = 'İlçelere Göre Masaj' } = Astro.props;
const items = DISTRICTS.filter((d) => d.slug !== exclude);
---

<section aria-labelledby="ilce-nav-baslik">
	<div class="flex items-center gap-4 pb-3 pt-9 md:pt-12">
		<span aria-hidden class="h-px flex-1 bg-border"></span>
		<h2 id="ilce-nav-baslik" class="font-display text-lg uppercase tracking-[0.2em] text-foreground md:text-2xl">
			{title}
		</h2>
		<span aria-hidden class="h-px flex-1 bg-border"></span>
	</div>

	<p class="mb-5 max-w-2xl text-sm leading-relaxed text-muted-foreground">
		İstanbul’un 39 ilçesinde profesyonel masaj ve masör hizmeti. Bulunduğunuz ilçeyi
		seçerek size en yakın masörlere ve o bölgeye özel bilgilere ulaşın.
	</p>

	<nav aria-label="İstanbul ilçelerine göre masaj sayfaları">
		<ul class="grid grid-cols-2 gap-x-4 gap-y-1.5 xs:grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6">
			{items.map((d) => (
				<li>
					<a
						href={`/${d.slug}`}
						class="inline-flex rounded py-1 text-sm text-muted-foreground transition-colors hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary"
					>
						{d.name} Masaj
					</a>
				</li>
			))}
		</ul>
	</nav>
</section>
