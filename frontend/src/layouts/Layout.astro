---
import '../index.css';
import { Toaster } from '../components/toaster';

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = 'LUXE AGENCY — seçkin manken ajansı.',
} = Astro.props;
---

<!doctype html>
<html lang="tr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="keywords" content="manken, model, ajans, cast, profesyonel model ajansı, oyunculuk, etkinlik, defile, luxe agency" />
		<meta name="robots" content="index, follow" />
		<meta name="author" content="Luxe Agency" />
		<link rel="canonical" href={Astro.url.href} />

		{/* Open Graph (Sosyal Medya) */}
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url.href} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/favicon.svg" />
		<meta property="og:site_name" content="Luxe Agency" />

		{/* Twitter Cards */}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={Astro.url.href} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="/favicon.svg" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400..900;1,6..96,400..600&family=Hanken+Grotesk:wght@300..800&display=swap"
			rel="stylesheet"
		/>

		{/* Apply theme before paint to avoid a flash of the wrong palette.
		    Default is light (the brand's white editorial theme); users opt into
		    dark via the header toggle, persisted under `luxe-theme`. */}
		<script is:inline>
			(function () {
				try {
					var stored = localStorage.getItem('luxe-theme');
					var theme = stored === 'dark' ? 'dark' : 'light';
					var root = document.documentElement;
					root.classList.toggle('dark', theme === 'dark');
					root.style.colorScheme = theme;
				} catch (e) {
					/* storage unavailable — default light applies */
				}
			})();
		</script>

		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-background text-foreground antialiased selection:bg-primary/25 selection:text-primary-foreground">
		<Toaster client:load />
		<slot />
	</body>
</html>
